---
import { Icon } from 'astro-icon/components';
import { getBlogPermalink } from '~/utils/permalinks';
import { I18N } from 'astrowind:config';
import Button from '~/components/ui/Button.astro';

const { textDirection } = I18N;
---

<div class="mx-auto px-6 sm:px-6 max-w-5xl pt-8 md:pt-4 pb-12 md:pb-20">
  <Button
    variant="tertiary"
    class="!rounded-xl !border !border-slate-200 !bg-white/90 !px-4 !py-2.5 !text-slate-700 hover:!border-primary hover:!text-primary dark:!border-white/15 dark:!bg-[#0b1222] dark:!text-slate-200 dark:hover:!border-[#f6b648] dark:hover:!text-[#f6b648]"
    href={getBlogPermalink()}
  >
    {
      textDirection === 'rtl' ? (
        <Icon name="tabler:chevron-right" class="w-5 h-5 mr-1 -ml-1.5 rtl:-mr-1.5 rtl:ml-1" />
      ) : (
        <Icon name="tabler:chevron-left" class="w-5 h-5 mr-1 -ml-1.5 rtl:-mr-1.5 rtl:ml-1" />
      )
    } Retour aux articles
  </Button>
</div>
