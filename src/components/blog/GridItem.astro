---
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

import Image from '~/components/common/Image.astro';

import { findImage } from '~/utils/images';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = await findImage(post.image);

const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
---

<article
  class="overflow-hidden rounded-xl border border-slate-200 bg-white/90 shadow-sm transition hover:-translate-y-0.5 hover:border-primary/70 dark:border-white/10 dark:bg-[#0f172b] dark:shadow-[0_14px_30px_rgba(0,0,0,0.35)] dark:hover:border-[#f6b648]/60 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
>
  <div class="relative md:h-52 bg-slate-200 dark:bg-slate-800">
    {
      image &&
        (link ? (
          <a href={link}>
            <Image
              src={image}
              class="w-full md:h-full object-cover"
              widths={[400, 900]}
              width={900}
              height={506}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title}
              format="webp"
              loading="lazy"
              decoding="async"
            />
          </a>
        ) : (
          <Image
            src={image}
            class="w-full md:h-full object-cover"
            widths={[400, 900]}
            width={900}
            height={506}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post.title}
            format="webp"
            loading="lazy"
            decoding="async"
          />
        ))
    }
  </div>

  <div class="p-4">
  <h3 class="text-xl font-bold leading-tight mb-2 font-heading text-slate-900 dark:text-slate-100">
    {
      link ? (
        <a class="inline-block transition ease-in duration-200 hover:text-primary dark:hover:text-[#f6b648]" href={link}>
          {post.title}
        </a>
      ) : (
        post.title
      )
    }
  </h3>

  <p class="text-slate-600 dark:text-slate-300 text-sm">{post.excerpt}</p>
  </div>
</article>
