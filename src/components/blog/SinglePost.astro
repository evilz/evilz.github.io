---
import { Icon } from 'astro-icon/components';

import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';

import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';
import { siteData } from '~/data/siteData';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
const displayAuthor = post.author === 'evilz' ? siteData.name : post.author;
---

<section class="relative overflow-hidden p-6 bg-[#05070f]">
  <div class="pointer-events-none absolute -top-24 left-1/2 h-72 w-72 -translate-x-1/2 bg-[#f6b648]/20 blur-3xl"></div>
  <div class="pointer-events-none absolute right-[-10%] top-20 h-80 w-80 rounded-full bg-[#6541ff]/20 blur-3xl"></div>

  <article>
    <header class="p-5 sm:p-8 shadow-sm dark:border-white/10">
      <div class="flex justify-between flex-col sm:flex-row max-w-4xl mx-auto mt-0 mb-3 sm:items-center">
        <p class="text-sm text-slate-600 dark:text-slate-300">
          <Icon name="tabler:clock" class="w-4 h-4 inline-block -mt-0.5 text-slate-500 dark:text-slate-400" />
          <time datetime={post.publishDate.toISOString()} class="inline-block"
            >{getFormattedDate(post.publishDate)}</time
          >
          {
            displayAuthor && (
              <>
                {' '}
                · <Icon name="tabler:user" class="w-4 h-4 inline-block -mt-0.5 text-slate-500 dark:text-slate-400" />
                <span class="inline-block">{displayAuthor}</span>
              </>
            )
          }
          {
            post.category && (
              <>
                {' '}
                ·{' '}
                <a
                  class="inline-block hover:text-primary dark:hover:text-[#f6b648]"
                  href={getPermalink(post.category.slug, 'category')}
                >
                  {post.category.title}
                </a>
              </>
            )
          }
          {
            post.readingTime && (
              <>
                &nbsp;· <span>{post.readingTime}</span> min read
              </>
            )
          }
        </p>
      </div>

      <h1
        class="max-w-4xl mx-auto text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading text-slate-900 dark:text-slate-100"
      >
        {post.title}
      </h1>
      <p class="max-w-4xl mx-auto mt-4 mb-8 text-lg md:text-xl text-slate-700 dark:text-slate-300 text-justify">
        {post.excerpt}
      </p>

      {
        post.image ? (
          <Image
            src={post.image}
            class="max-w-full lg:max-w-[980px] mx-auto mb-2 rounded-xl border border-slate-200 bg-slate-200 dark:border-white/10 dark:bg-slate-800"
            widths={[400, 900]}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post?.excerpt || ''}
            width={900}
            height={506}
            format="webp"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="max-w-4xl mx-auto">
            <div class="border-t border-slate-200 dark:border-white/10" />
          </div>
        )
      }
    </header>
    <div
      class="mx-auto px-5 sm:px-8 py-7 max-w-4xl shadow-sm prose prose-md lg:prose-xl
      dark:prose-invert dark:prose-headings:text-slate-200
      prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter
      prose-headings:font-bold prose-a:text-primary dark:prose-a:text-[#f6b648] prose-img:rounded-xl
      prose-img:shadow-lg mt-8 prose-headings:scroll-mt-[80px] prose-li:my-0"
    >
      <slot />
    </div>
    <div class="mx-auto px-1 sm:px-1 max-w-4xl mt-8 flex justify-between gap-4 flex-col sm:flex-row">
      <PostTags tags={post.tags} class="mr-5 rtl:mr-0 rtl:ml-5" />
      <SocialShare
        url={url}
        text={post.title}
        class="mt-2 sm:mt-1 align-middle text-slate-500 dark:text-slate-400 bg-transparent"
      />
    </div>
  </article>
</section>
