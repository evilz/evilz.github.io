---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { siteData } from '~/data/siteData';

const metadata = {
  title: 'Staff',
  description: 'Meet our team.',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Staff" title="Staff" subtitle="Meet our team." />
  <section class="px-4 sm:px-6 py-4 mx-auto max-w-4xl">
    <div
      class="rounded-2xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm p-8 flex flex-col sm:flex-row gap-6 items-center sm:items-start"
    >
      <img src={siteData.image} alt={siteData.name} class="h-28 w-28 rounded-full object-cover" />
      <div>
        <h2 class="text-2xl font-bold font-heading">{siteData.name}</h2>
        <p class="mt-2 text-muted dark:text-slate-400">{siteData.role}</p>
        <p class="mt-4">{siteData.bio}</p>
      </div>
    </div>
  </section>
</Layout>
