---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Stats from '~/components/widgets/Stats.astro';
import Button from '~/components/ui/Button.astro';

import { getBlogPermalink, getPermalink } from '~/utils/permalinks';
import { contentSummary } from '~/data/contentSummary';
import { siteData } from '~/data/siteData';

const metadata = {
  title: 'Evilz blog',
  ignoreTitleTemplate: true,
  description: 'Code for Human',
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[{ variant: 'primary', text: 'Lire les articles', href: getBlogPermalink() }]}
   
  >
    <Fragment slot="title">
      Code for 
      <span class="text-accent dark:text-white">Human</span>
    </Fragment>

    <Fragment slot="subtitle">
Code, architecture, outils, IA et bidouilles high-tech : retour d’expérience d’un dev qui aime comprendre, construire et partager.
      </Fragment>
      
  </Hero>

  <BlogLatestPosts
    title="Derniers articles"
    linkText="Voir toutes les archives"
    count={8}
  />

    <Fragment slot="after">
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <Button href={getPermalink('/tags')} variant="secondary">Tous les tags</Button>
      </div>
    </Fragment>
  </Features2>
</Layout>
