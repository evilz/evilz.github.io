---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Button from '~/components/ui/Button.astro';
import { siteData } from '~/data/siteData';

const metadata = {
  title: 'Contact',
  description: "Let's talk.",
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Let's talk."
    subtitle="Les meilleurs points d’entrée pour me joindre restent l’email et les réseaux ci-dessous."
  />

  <section class="px-4 sm:px-6 py-4 mx-auto max-w-5xl">
    <div
      class="rounded-2xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm p-8 text-center"
    >
      <img src={siteData.image} alt={siteData.name} class="mx-auto mb-6 h-24 w-24 rounded-full object-cover" />
      <h2 class="text-2xl font-bold font-heading">{siteData.name}</h2>
      <p class="mt-2 text-muted dark:text-slate-400">{siteData.role}</p>
      <div class="mt-6 flex flex-wrap gap-3 justify-center">
        <Button href={`mailto:${siteData.email}`} variant="primary" icon="tabler:mail">{siteData.email}</Button>
        <Button href={siteData.github} variant="secondary" target="_blank" icon="tabler:brand-github">GitHub</Button>
        <Button href={siteData.twitter} variant="secondary" target="_blank" icon="tabler:brand-x">X / Twitter</Button>
      </div>
    </div>
  </section>

  <Features2
    title="Autres accès"
    items={[
      { title: 'Email', description: siteData.email, icon: 'tabler:mail' },
      { title: 'GitHub', description: 'github.com/evilz', icon: 'tabler:brand-github' },
      { title: 'X / Twitter', description: '@Evilznet', icon: 'tabler:brand-x' },
      { title: 'Site principal', description: 'www.evilznet.com', icon: 'tabler:world-www' },
    ]}
  />
</Layout>
