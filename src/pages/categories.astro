---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/blog/Headline.astro';
import { fetchPosts } from '~/utils/blog';
import { categoryDetails } from '~/data/categoryDetails';
import { getPermalink } from '~/utils/permalinks';

const posts = await fetchPosts();
const counts = new Map<string, number>();
for (const post of posts) {
  if (post.category?.slug) counts.set(post.category.slug, (counts.get(post.category.slug) || 0) + 1);
}
const metadata = {
  title: 'Catégories',
  description: 'Catégories historiques du blog.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 sm:px-6 py-10 sm:py-14 lg:py-16 mx-auto max-w-6xl">
    <div
      class="rounded-2xl border border-slate-200 bg-white/90 p-5 md:p-8 shadow-sm dark:border-white/10 dark:bg-[#0b1222] dark:shadow-[0_20px_45px_rgba(0,0,0,0.35)]"
    >
      <Headline
        subtitle="Les catégories historiques du blog sont conservées, avec leur description d’origine lorsque disponible."
        >Catégories</Headline
      >
      <div class="grid sm:grid-cols-2 gap-5">
        {
          categoryDetails.map((category) => (
            <a
              href={getPermalink(category.slug, 'category')}
              class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-primary hover:-translate-y-0.5 dark:border-white/10 dark:bg-[#0f172b] dark:hover:border-[#f6b648]/60"
            >
              <div class="flex items-center justify-between gap-4">
                <h2 class="text-xl font-bold font-heading text-slate-900 dark:text-slate-100">{category.title}</h2>
                <span class="text-sm text-slate-500 dark:text-slate-400">
                  {counts.get(category.slug) || 0} article(s)
                </span>
              </div>
              <p class="mt-3 text-slate-600 dark:text-slate-300">
                {category.description || 'Catégorie conservée depuis le blog précédent.'}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
